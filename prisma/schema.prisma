// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EmailVerificationPurpose {
  register
  reset_password
}

enum TemplateSource {
  seed
  ai
  user
  learned
}

model User {
  id            String   @id @default(cuid())
  code          Int      @unique @default(autoincrement())
  email         String   @unique
  name          String?
  passwordHash  String?
  emailVerified Boolean  @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  templateUsages       CreateTemplateUsage[]
  ideaGenerationEvents IdeaGenerationEvent[]
  aiUsageEvents        AiUsageEvent[]
  works               Work[]
}

model EmailVerificationCode {
  id        String                   @id @default(cuid())
  email     String
  purpose   EmailVerificationPurpose
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime                 @default(now())

  @@index([email, purpose, createdAt(sort: Desc)])
}

model AppConfig {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreateTemplate {
  id         String         @id @default(cuid())
  genreId    String
  title      String?
  content    String
  source     TemplateSource @default(seed)
  usageCount Int            @default(0)
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  usageEvents CreateTemplateUsage[]

  @@index([genreId, usageCount(sort: Desc), updatedAt(sort: Desc)])
}

model CreateTemplateUsage {
  id         String   @id @default(cuid())
  templateId String
  userId     String?
  createdAt  DateTime @default(now())

  template CreateTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user     User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([templateId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model IdeaGenerationEvent {
  id        String   @id @default(cuid())
  userId    String?
  genreId   String
  tags      String[]
  platformId String?
  dnaStyleId String?
  wordsId    String?
  inputIdea String?
  outputIdea String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([genreId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model AiUsageEvent {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  providerId   String?
  endpoint     String?
  modelUsed    String?
  status       Int
  success      Boolean  @default(false)
  inputTokens  Int?
  outputTokens Int?
  totalTokens  Int?
  durationMs   Int?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model Work {
  id            String   @id @default(cuid())
  userId        String
  genreId       String
  genreLabel    String?
  idea          String
  tags          String[]
  platformId    String?
  platformLabel String?
  words         String?
  dnaBookTitle  String?
  tag           String
  title         String
  synopsis      String
  outline       Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapters Chapter[]

  @@index([userId, updatedAt(sort: Desc)])
}

model Chapter {
  id        String   @id @default(cuid())
  workId    String
  index     Int
  title     String?
  content   String   @default("")
  wordCount Int      @default(0)
  summary        String?
  chapterOutline String?
  details        Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([workId, index])
  @@index([workId, index])
  @@index([workId, updatedAt(sort: Desc)])
}
